# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Comma-separated list of allowed hostnames (required in production)
# ALLOWED_HOSTS=your-app.railway.app,your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.railway.app,https://your-app.vercel.app

# Email (Gmail SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Proxy for scraping
PROXY_ADDRESS=

# API Keys
SCRAPING_API_KEY=
GOOGLE_STREET_VIEW_API_KEY=

# File paths (optional, defaults to BASE_DIR/exports)
EXCEL_PATH=
PDF_PATH=

# Database (optional, defaults to SQLite)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Celery (optional, defaults to memory:// for local dev)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging (optional, defaults to INFO)
# LOG_LEVEL=DEBUG
