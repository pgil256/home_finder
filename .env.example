# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Database (defaults to SQLite if not set)
DATABASE_URL=

# Redis / Celery (defaults to memory:// if not set)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=

# Email (Gmail SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Document export paths (defaults to ./exports)
EXCEL_PATH=
PDF_PATH=

# Scraping
PROXY_ADDRESS=
SCRAPING_API_KEY=

# Google Street View
GOOGLE_STREET_VIEW_API_KEY=

# Logging
LOG_LEVEL=INFO

# Sentry (optional - leave blank to disable)
SENTRY_DSN=
